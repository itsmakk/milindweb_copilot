{
  "name": "@milindweb/db",
  "version": "0.1.0",
  "private": true,
  "description": "Migrations, seeds, and schema docs for MilindWeb",
  "scripts": {
    "migrate:up": "node-pg-migrate -m migrations -j sql up",
    "migrate:down": "node-pg-migrate -m migrations -j sql down 1",
    "migrate:redo": "node-pg-migrate -m migrations -j sql redo",
    "migrate:status": "node-pg-migrate -m migrations -j sql status",
    "migrate:create": "node-pg-migrate -m migrations create"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.13.1",
    "typescript": "5.6.3"
  }
}
