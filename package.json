{
  "name": "milindweb",
  "version": "0.1.0",
  "private": true,
  "description": "MilindWeb monorepo — static site (Cloudflare Pages) + NestJS API (Render) + Cloudflare Worker (api/*) + InsForge (DB/storage/auth)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./api\" dev",
    "build": "pnpm -r --filter \"./shared\" build && pnpm -r --filter \"./api\" build",
    "start": "pnpm --filter @milindweb/api start",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",

    "migrate:insforge": "node scripts/db-migrate-insforge.mjs",
    "seed:insforge": "node scripts/db-seed-insforge.mjs",
    "storage:bootstrap": "node scripts/storage-bootstrap.mjs",
    "bootstrap:insforge": "pnpm migrate:insforge && pnpm seed:insforge && pnpm storage:bootstrap",

    "worker:dev": "pnpm dlx wrangler dev",
    "worker:deploy": "pnpm dlx wrangler deploy --env production",
    "worker:login": "pnpm dlx wrangler login",

    "audit": "python3 scripts/audit.py"
  },
  "devDependencies": {
    "@insforge/sdk": "^1.3.1",
    "typescript": "5.6.3"
  }
}
